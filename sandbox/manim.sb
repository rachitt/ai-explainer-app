;;
;; Pedagogica Manim sandbox profile (Phase 1, macOS sandbox-exec).
;;
;; Threat model: Manim code is LLM-generated. Profile must prevent
;;   - any outbound network (no exfil, no remote shells, no crypto mining),
;;   - any filesystem write outside the job's artifact directory,
;; while still letting Python + Manim + LaTeX run.
;;
;; Phase 4 replaces this with Firecracker (see docs/ARCHITECTURE.md §9).
;;
;; Parameters (pass via `sandbox-exec -D`):
;;   ARTIFACT_DIR   absolute path to the only directory subtree that may be
;;                  written to (scene work dir + tmpdir live inside it).
;;

(version 1)

;; Start permissive — we enforce the two properties we care about
;; (no network-outbound, no writes outside ARTIFACT_DIR) with explicit
;; deny rules below. Phase 4 moves to Firecracker for true isolation.
(allow default)

;; -------- filesystem writes: artifact dir only --------
(deny file-write*)
(allow file-write*
    (subpath (param "ARTIFACT_DIR")))
(allow file-write*
    (literal "/dev/null")
    (literal "/dev/dtracehelper")
    (literal "/dev/stdout")
    (literal "/dev/stderr")
    (regex #"^/dev/fd/[0-9]+$")
    (regex #"^/dev/tty[a-z0-9]*$"))

;; -------- network: deny outbound, allow loopback + unix sockets --------
;; Unix sockets to system daemons (mach bootstrap, syslog, etc) are needed
;; for Python / Manim to start; they don't let code reach the internet.
(deny network*)
(allow network-bind)
(allow network-inbound (local ip))
(allow network* (local ip))
(allow network-outbound (remote ip "localhost:*"))
(allow network-outbound (remote unix-socket))
(allow system-socket)
